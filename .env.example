# Kesari AI — Environment Variables
# Get your NVIDIA API key from https://build.nvidia.com/explore/llm
NVIDIA_API_KEY=
# Get your API key from https://dashboard.sarvam.ai/
SARVAM_API_KEY=


# Default LLM model (NVIDIA NIM models)
# Options: meta/llama-3.3-70b-instruct, meta/llama-3.2-90b-vision-instruct, nvidia/nemotron-4-340b-instruct
DEFAULT_MODEL=meta/llama-3.3-70b-instruct
